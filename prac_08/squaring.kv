BoxLayout:
    orientation: 'vertical'

    BoxLayout:
        orientation: 'horizontal'
        spacing: 10
        padding: 10

        TextInput:
            id: input_number
            text: ''
            font_size: 32
            multiline: False
            hint_text: 'Enter a number'

        Button:
            text: 'Square'
            font_size: 24
            on_press: app.handle_calculate(input_number.text)

        Label:
            id: output_label
            text: ''
            font_size: 32
            color: (1, 0.75, 0.8, 1)  # Pink color

    Label:
        text: 'Enter a number and press "Square"'
        font_size: 18
        size_hint_y: None
        height: 30
        halign: 'center'
